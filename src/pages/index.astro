---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';

const posts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group by year
const grouped = posts.reduce((acc, post) => {
  const year = post.data.date.getFullYear().toString();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {} as Record<string, typeof posts>);

const years = Object.keys(grouped).sort((a, b) => b.localeCompare(a));

const typeColors: Record<string, string> = {
  RCA: 'text-red-600',
  ESSAY: 'text-blue-600',
  NOTE: 'text-emerald-600',
};

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }).toUpperCase();
};
---

<BaseLayout title="sidechannels.pub">
  <!-- DARK HERO SECTION -->
  <section class="hero-section relative overflow-hidden">
    <!-- Animated grid background -->
    <div class="hero-grid-bg" aria-hidden="true"></div>

    <!-- Nav integrated into hero -->
    <nav class="relative z-10 flex items-center justify-between px-8 md:px-12 py-6">
      <a href="/" class="hero-logo">SIDE<span>CHANNELS</span></a>
      <div class="flex items-center gap-8">
        <a href="/" class="hero-nav-link">Archive</a>
        <a href="/about" class="hero-nav-link">About</a>
        <a href="/rss.xml" class="hero-nav-link">RSS</a>
      </div>
    </nav>

    <!-- Hero content -->
    <div class="relative z-10 px-8 md:px-12 pb-20 pt-16 md:pt-24">
      <div class="max-w-[900px]">
        <div class="hero-label mb-6">Technical Research</div>

        <h1 class="hero-title">
          Experimental writing<br/>at the edge
        </h1>

        <p class="hero-subtitle max-w-[50ch] mt-8">
          Tracing assumptions and questioning what isn't mainstream. Security research, interpretability, and formal methods.
        </p>

        <!-- Pillars as horizontal chips -->
        <div class="flex flex-wrap gap-3 mt-12">
          <span class="hero-chip">Security</span>
          <span class="hero-chip">Interpretability</span>
          <span class="hero-chip">Verification</span>
          <span class="hero-chip-accent">RCA</span>
          <span class="hero-chip-accent">Essays</span>
          <span class="hero-chip-accent">Notes</span>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="relative z-10 flex justify-center pb-8">
      <div class="hero-scroll-indicator">
        <span class="hero-scroll-dot"></span>
      </div>
    </div>
  </section>

  <!-- LIGHT POST LISTING -->
  <main class="max-w-[680px] mx-auto px-6 pt-24 pb-48 bg-[var(--bg-body)]">
    <section class="space-y-20">
      {years.map(year => (
        <div>
          <div class="font-mono text-[11px] text-gray-400 uppercase tracking-[0.5em] mb-8 border-b border-gray-100 pb-3">
            {year}
          </div>
          <div class="space-y-12">
            {grouped[year].map(post => (
              <article class="group">
                <div class="flex items-baseline gap-4 mb-2 font-mono text-[11px] uppercase tracking-[0.2em]">
                  <time datetime={post.data.date.toISOString()} class="text-gray-400 w-16 flex-shrink-0">
                    {formatDate(post.data.date)}
                  </time>
                  <span class={`font-bold ${typeColors[post.data.type] || 'text-gray-500'}`}>
                    {post.data.type}
                  </span>
                </div>
                <a href={`/posts/${post.id}/`} class="block no-underline">
                  <h2 class="text-2xl md:text-3xl font-medium text-black group-hover:text-gray-600 transition-colors leading-tight font-serif tracking-tight mb-3">
                    {post.data.title}
                  </h2>
                </a>
                <p class="text-[15px] text-gray-500 font-serif leading-relaxed mb-3 max-w-[60ch]">
                  {post.data.summary}
                </p>
                <div class="flex flex-wrap gap-4 font-mono text-[10px] uppercase tracking-[0.15em] text-gray-400">
                  {post.data.tags.map(tag => (
                    <span class="hover:text-black transition-colors">#{tag}</span>
                  ))}
                  {post.data.rcaMetadata?.cveId && (
                    <span class="font-bold text-gray-500">{post.data.rcaMetadata.cveId}</span>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      ))}
    </section>
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  /* === DARK HERO === */
  .hero-section {
    background: #080808;
    min-height: 85vh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .hero-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    animation: hero-grid-drift 20s linear infinite;
  }

  @keyframes hero-grid-drift {
    0% { transform: translate(0, 0); }
    100% { transform: translate(60px, 60px); }
  }

  .hero-logo {
    font-family: 'Bebas Neue', 'Lora', sans-serif;
    font-size: 1.5rem;
    letter-spacing: 0.08em;
    color: #f0f0f0;
    text-decoration: none;
  }

  .hero-logo span {
    color: #c8f135;
  }

  .hero-nav-link {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #666;
    text-decoration: none;
    transition: color 0.2s;
  }

  .hero-nav-link:hover {
    color: #f0f0f0;
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: #c8f135;
  }

  .hero-title {
    font-family: 'Bebas Neue', 'Lora', sans-serif;
    font-size: clamp(3rem, 8vw, 6.5rem);
    line-height: 0.95;
    letter-spacing: -0.01em;
    color: #f0f0f0;
    font-weight: 400;
  }

  .hero-subtitle {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    line-height: 1.7;
    color: #888;
    font-weight: 400;
  }

  .hero-chip {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #888;
    border: 1px solid #333;
    padding: 0.35rem 0.9rem;
    transition: all 0.2s;
  }

  .hero-chip:hover {
    border-color: #f0f0f0;
    color: #f0f0f0;
  }

  .hero-chip-accent {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #080808;
    background: #c8f135;
    padding: 0.35rem 0.9rem;
    font-weight: 500;
  }

  .hero-scroll-indicator {
    width: 1.5rem;
    height: 2.5rem;
    border: 1px solid #444;
    border-radius: 999px;
    display: flex;
    justify-content: center;
    padding-top: 0.4rem;
  }

  .hero-scroll-dot {
    width: 3px;
    height: 8px;
    background: #c8f135;
    border-radius: 999px;
    animation: hero-scroll-bounce 2s ease-in-out infinite;
  }

  @keyframes hero-scroll-bounce {
    0%, 100% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(8px); opacity: 0.3; }
  }

  /* Load Bebas Neue for hero */
  @font-face {
    font-family: 'Bebas Neue';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url('https://fonts.gstatic.com/s/bebasneue/v14/JTUSjIg69CK48gW7PXoo9Wdhyzbi.woff2') format('woff2');
  }
</style>
