---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="404 — sidechannels.pub">
  <Header />
  <main class="max-w-[680px] mx-auto px-6 pt-32 pb-48 text-center">
    <div class="font-mono text-[10px] uppercase tracking-[0.4em] text-gray-400 mb-6">404</div>
    <h1 class="text-4xl font-serif font-medium text-black mb-6">Page not found</h1>
    <p class="text-gray-500 font-serif mb-12">The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="font-mono text-[11px] uppercase tracking-[0.2em] text-black hover:text-gray-600 transition-colors no-underline border-b border-black pb-1">
      Back to archive
    </a>
  </main>
  <Footer />
</BaseLayout>
